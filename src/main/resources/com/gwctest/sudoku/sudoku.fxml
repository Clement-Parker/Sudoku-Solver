<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.scene.layout.BorderPane?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>

<BorderPane xmlns:fx="http://javafx.com/fxml"
            fx:controller="com.gwctest.sudoku.SudokuController"
            stylesheets="@styles.css" styleClass="root">
    <top>
        <VBox alignment="CENTER" style="-fx-padding: 20;">
            <Label fx:id="boardLabel" text="Board: 1/20" style="-fx-font-size: 24px; -fx-font-weight: bold; -fx-text-fill: #2c3e50;"/>
        </VBox>
    </top>
    <center>
        <GridPane fx:id="gridPane" styleClass="grid-pane" alignment="CENTER"/>
    </center>
    <right>
        <VBox spacing="20" alignment="CENTER" style="-fx-padding: 40;">
            <Button text="Killer Sudoku" onAction="#handleToggleMode" styleClass="mode-button"/>
            <Button text="Auto Solve" onAction="#handleAutoSolve" styleClass="solve-button"/>
            <Button text="Next Board" onAction="#handleReset" styleClass="reset-button"/>
            <Label text="Red = u fckd it up" style="-fx-text-fill: #e74c3c; -fx-font-weight: bold;"/>
        </VBox>
    </right>
</BorderPane>